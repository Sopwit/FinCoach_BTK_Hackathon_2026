# === AI Servisi (Gemini) ===
GEMINI_API_KEY=your_gemini_api_key_here
# GOOGLE_API_KEY=alternatif_anahtar
# GOOGLE_GENERATIVE_AI_API_KEY=alternatif_anahtar_2
# GEMINI_MODEL=gemini-2.5-flash-lite

# === AI Davranis ===
# FINCOACH_AI_DEBUG=false
# AI_RAISE_ERRORS=false
# AI_ADVICE_CACHE_TTL_SECONDS=300

# === Veritabani (varsayilan: SQLite — local'de calisir) ===
# Neon / Vercel Postgres / herhangi bir PostgreSQL icin su variable'lardan
# birini Vercel Dashboard'da Environment Variable olarak ekle:
#   POSTGRES_URL_NON_POOLING  (oncesi: Vercel Postgres kurulumu)
#   DATABASE_URL              (herhangi bir PostgreSQL URL)
#
# DATABASE_URL=postgresql://user:pass@host:5432/db
# POSTGRES_URL_NON_POOLING=postgresql://user:pass@host:5432/db
# POSTGRES_URL=postgresql://user:pass@host:5432/db
# POSTGRES_PRISMA_URL=postgresql://user:pass@host:5432/db

# === JWT Auth ===
# JWT_SECRET_KEY=your-secret-key-here
# JWT_EXPIRE_MINUTES=1440

# === CORS ===
# CORS_ORIGINS=http://localhost:5173,https://fincoach.vercel.app
